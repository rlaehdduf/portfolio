---
const pathname = Astro.url.pathname;

// 프로젝트 타입별 정보
const projectTypes = [
  { value: 'unity', label: 'Unity', count: 4 },
  { value: 'web', label: 'Web', count: 1 },
  { value: 'package', label: 'Package', count: 1 },
  { value: 'server', label: 'Server', count: 1 },
  { value: 'docs', label: 'Docs', count: 1 },
];
---

<header>
  <nav>
    <a href="/" class="nav-link">
      Portfolio
    </a>
    <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" type="button">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
  
  <div class="filter-menu" id="filterMenu">
    <div class="filter-header">
      <h3>🔍 필터</h3>
      <button class="close-btn" id="closeBtn" aria-label="Close menu">&times;</button>
    </div>
    
    <div class="filter-content">
      <!-- All 옵션 -->
      <div class="filter-item">
        <label class="filter-label">
          <input type="checkbox" value="all" checked id="allCheckbox">
          <span class="filter-label-text">📋 All Projects</span>
        </label>
      </div>
      
      <!-- 타입별 폴더 구조 -->
      <div class="filter-section">
        <button class="folder-toggle" id="folderToggle">
          <span class="folder-icon">📁</span>
          <span>By Type</span>
          <span class="folder-arrow">▼</span>
        </button>
        
        <div class="folder-content" id="folderContent">
          {projectTypes.map((type) => (
            <label class="filter-option">
              <input type="checkbox" value={type.value}>
              <span class="type-icon">📄</span>
              <span class="type-name">{type.label}</span>
              <span class="type-count">({type.count})</span>
            </label>
          ))}
        </div>
      </div>
      
      <div class="filter-info">
        <p>✅ 체크된 타입만 표시</p>
        <p>🔄 All 이 체크되면 전체 표시</p>
      </div>
    </div>
  </div>
</header>

<style>
  header {
    padding: 1rem 2rem;
    background: linear-gradient(180deg, rgba(45, 47, 50, 0.98) 0%, rgba(35, 37, 39, 0.95) 100%);
    backdrop-filter: blur(15px);
    border-bottom: 1px solid rgba(120, 123, 126, 0.3);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav-link {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--text);
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--primary);
  }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 10px;
    z-index: 102;
    position: relative;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .menu-toggle:hover {
    background: rgba(100, 103, 106, 0.3);
    border-color: rgba(120, 123, 126, 0.5);
  }

  .menu-toggle:hover span {
    background: #e5e7eb;
  }

  .menu-toggle:active {
    transform: scale(0.95);
    background: rgba(100, 103, 106, 0.4);
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -6px);
  }

  .menu-toggle span {
    width: 25px;
    height: 3px;
    background: #d1d5db;
    border-radius: 2px;
    transition: all 0.3s ease;
    display: block;
  }

  .filter-menu {
    position: fixed;
    top: 80px;
    right: -350px;
    width: 320px;
    background: linear-gradient(180deg, rgba(50, 52, 55, 0.98) 0%, rgba(40, 42, 45, 0.95) 100%);
    border: 1px solid rgba(90, 93, 96, 0.5);
    border-radius: 12px;
    padding: 0;
    box-shadow: 
      0 10px 40px rgba(0, 0, 0, 0.5),
      0 0 60px rgba(0, 0, 0, 0.3);
    transition: right 0.3s ease;
    z-index: 99;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    backdrop-filter: blur(15px);
  }

  .filter-menu.open {
    right: 20px;
  }

  .filter-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem;
    border-bottom: 1px solid rgba(90, 93, 96, 0.5);
    background: linear-gradient(180deg, rgba(60, 62, 65, 0.9) 0%, rgba(50, 52, 55, 0.8) 100%);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .filter-header h3 {
    color: #e5e7eb;
    font-size: 1.125rem;
    margin: 0;
  }

  .close-btn {
    background: rgba(90, 93, 96, 0.3);
    border: 1px solid rgba(110, 113, 116, 0.4);
    color: #d1d5db;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .close-btn:hover {
    color: #ffffff;
    background: rgba(100, 103, 106, 0.5);
    border-color: rgba(120, 123, 126, 0.6);
  }

  .filter-content {
    padding: 1rem;
  }

  .filter-item {
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: rgba(70, 72, 75, 0.4);
    border-radius: 8px;
    border: 1px solid rgba(90, 93, 96, 0.4);
  }

  .filter-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    font-weight: 600;
  }

  .filter-label input[type="checkbox"] {
    width: 20px;
    height: 20px;
    accent-color: #9ca3af;
    cursor: pointer;
  }

  .filter-label-text {
    color: #e5e7eb;
    font-size: 1rem;
  }

  .filter-section {
    margin-bottom: 1rem;
  }

  .folder-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(80, 82, 85, 0.5);
    border: 1px solid rgba(100, 103, 106, 0.5);
    padding: 0.75rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    color: #e5e7eb;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .folder-toggle:hover {
    background: rgba(90, 93, 96, 0.5);
    border-color: rgba(110, 113, 116, 0.6);
  }

  .folder-icon {
    font-size: 1.25rem;
  }

  .folder-arrow {
    margin-left: auto;
    transition: transform 0.3s ease;
    font-size: 0.75rem;
  }

  .folder-toggle.active .folder-arrow {
    transform: rotate(180deg);
  }

  .folder-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background: rgba(50, 52, 55, 0.4);
    border-radius: 8px;
    margin-top: 0.5rem;
  }

  .folder-content.open {
    max-height: 500px;
    padding: 0.5rem;
  }

  .filter-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    padding: 0.625rem 0.75rem;
    border-radius: 6px;
    transition: background 0.2s;
    margin-bottom: 0.25rem;
  }

  .filter-option:hover {
    background: rgba(80, 82, 85, 0.5);
  }

  .filter-option input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: #9ca3af;
    cursor: pointer;
    flex-shrink: 0;
  }

  .type-icon {
    font-size: 1rem;
  }

  .type-name {
    color: #e5e7eb;
    font-size: 0.9rem;
    flex: 1;
  }

  .type-count {
    color: #9ca3af;
    font-size: 0.8rem;
    background: rgba(80, 82, 85, 0.5);
    padding: 0.125rem 0.5rem;
    border-radius: 10px;
    border: 1px solid rgba(100, 103, 106, 0.3);
  }

  .filter-info {
    margin-top: 1rem;
    padding: 0.75rem;
    background: rgba(60, 62, 65, 0.4);
    border-radius: 8px;
    border: 1px solid rgba(90, 93, 96, 0.3);
    font-size: 0.75rem;
    color: #9ca3af;
  }

  .filter-info p {
    margin: 0.25rem 0;
  }
</style>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const filterMenu = document.getElementById('filterMenu');
  const closeBtn = document.getElementById('closeBtn');
  const folderToggle = document.getElementById('folderToggle');
  const folderContent = document.getElementById('folderContent');
  const allCheckbox = document.getElementById('allCheckbox');
  const typeCheckboxes = filterMenu ? filterMenu.querySelectorAll('.filter-option input[type="checkbox"]') : [];

  console.log('Header script loaded');

  function toggleMenu() {
    menuToggle.classList.toggle('active');
    filterMenu.classList.toggle('open');
  }

  function toggleFolder() {
    folderToggle.classList.toggle('active');
    folderContent.classList.toggle('open');
  }

  menuToggle.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    toggleMenu();
  });

  closeBtn.addEventListener('click', toggleMenu);

  folderToggle.addEventListener('click', toggleFolder);

  document.addEventListener('click', function(e) {
    if (!filterMenu.contains(e.target) && !menuToggle.contains(e.target)) {
      filterMenu.classList.remove('open');
      menuToggle.classList.remove('active');
    }
  });

  filterMenu.addEventListener('click', function(e) {
    e.stopPropagation();
  });

  allCheckbox.addEventListener('change', function() {
    if (allCheckbox.checked) {
      typeCheckboxes.forEach(cb => cb.checked = false);
      updateFilters(['all']);
    } else {
      allCheckbox.checked = true;
    }
  });

  typeCheckboxes.forEach(checkbox => {
    checkbox.addEventListener('change', function() {
      if (this.checked) {
        allCheckbox.checked = false;
      }
      
      const selectedTypes = Array.from(typeCheckboxes)
        .filter(cb => cb.checked)
        .map(cb => cb.value);
      
      if (selectedTypes.length === 0) {
        allCheckbox.checked = true;
        updateFilters(['all']);
      } else {
        updateFilters(selectedTypes);
      }
    });
  });

  function updateFilters(types) {
    const cards = document.querySelectorAll('.project-card');
    cards.forEach(card => {
      const projectType = card.getAttribute('data-type');
      if (types.includes('all') || types.includes(projectType)) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
  }
</script>
