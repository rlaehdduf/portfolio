---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<span class="tech-badge">{name}</span>

<style>
  .tech-badge {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    background: linear-gradient(145deg, rgba(70, 72, 75, 0.8) 0%, rgba(50, 52, 55, 0.9) 100%);
    border: 1px solid rgba(90, 93, 96, 0.4);
    border-top: 1px solid rgba(110, 113, 116, 0.5);
    border-left: 1px solid rgba(110, 113, 116, 0.5);
    border-radius: 8px;
    font-size: 0.75rem;
    color: #d1d5db;
    font-weight: 500;
    backdrop-filter: blur(5px);
  }
</style>